# =============================================================================
# Autonomous Local Knowledge to Anki Pipeline - Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# -----------------------------------------------------------------------------
# REQUIRED: Siyuan Notes Configuration
# -----------------------------------------------------------------------------
# The block ID of the document/section you want to convert to flashcards
# Find this in Siyuan: Right-click a block -> Copy -> Copy block reference
TARGET_BLOCK_ID=

# Siyuan API token (optional if auth is disabled in Siyuan settings)
SIYUAN_API_TOKEN=

# Siyuan API URL (default works for local installation)
SIYUAN_API_URL=http://127.0.0.1:6806/api/block/getBlockKramdown

# -----------------------------------------------------------------------------
# LLM Server Configuration (Ollama with Intel GPU recommended)
# -----------------------------------------------------------------------------
# Base URL for your LLM server
LLM_BASE_URL=http://127.0.0.1:11434/v1

# Model ID - recommended: qwen2.5-coder:3b (best for function calling)
LLM_MODEL_ID=qwen2.5-coder:3b
# Provider - 'ollama' or 'openai' (affects specific optimizations)
LLM_PROVIDER=ollama
# Alternatives: gpt-4o-mini, phi4-mini:latest

# API Key (required for OpenAI, use "placeholder" for local servers)
LLM_API_KEY=placeholder

# -----------------------------------------------------------------------------
# Anki Configuration
# -----------------------------------------------------------------------------
# AnkiConnect URL (default port is 8765)
ANKI_CONNECT_URL=http://localhost:8765

# Target deck for new cards
ANKI_DECK_NAME=Default